#!/usr/bin/env bash
set -euo pipefail

# Container-internal lifecycle for the MCP server uvicorn process.
# All commands operate on a single uvicorn child tracked by a PID file.

PIDFILE="${PIDFILE:-/tmp/uvicorn.pid}"
LOGFILE="${LOGFILE:-/tmp/uvicorn.log}"
MCP_HOST="${MCP_HOST:-0.0.0.0}"
MCP_PORT="${MCP_PORT:-8000}"
GRACE_SECONDS="${GRACE_SECONDS:-10}"
MCP_TLS_DIR="${MCP_TLS_DIR:-/etc/tls_certs}"
SELF_SIGNED_DIR="/tmp/tls_selfsigned"
# Log rotation for the file sink (rotatelogs): rotate at LOG_MAX_SIZE, keep LOG_BACKUPS
# generations. The current log is always ${LOGFILE}; older ones are ${LOGFILE}.1 ...
LOG_MAX_SIZE="${LOG_MAX_SIZE:-10M}"
LOG_BACKUPS="${LOG_BACKUPS:-5}"

# Cert/key filename pairs recognised in MCP_TLS_DIR, in priority order: k8s TLS secret,
# Let's Encrypt, then generic PEM. First pair where both files exist wins.
TLS_CERT_PAIRS=(
    "tls.crt:tls.key"
    "fullchain.pem:privkey.pem"
    "cert.pem:key.pem"
)

cmd_status() {
    if [[ -f "${PIDFILE}" ]]; then
        local pid
        pid="$(cat "${PIDFILE}")"
        if kill -0 "${pid}" 2>/dev/null; then
            echo "running (PID ${pid})"
            return 0
        fi
        rm -f "${PIDFILE}"
    fi
    echo "stopped"
    return 1
}

# Preflight: decide the listener's transport from MCP_TLS_DIR before the server starts.
# Populates the global SSL_ARGS array (uvicorn flags) and TLS_SCHEME (http|https):
#   dir absent              -> HTTP, no flags
#   dir holds readable pair -> HTTPS with those certs
#   dir but no readable pair-> HTTPS with a self-signed cert generated into /tmp
# Readability is checked from this (the server) user, so a present-but-unreadable cert
# falls through to self-signed rather than crashing uvicorn at bind time.
resolve_tls() {
    SSL_ARGS=()
    TLS_SCHEME="http"

    if [[ ! -d "${MCP_TLS_DIR}" ]]; then
        echo "tls: no cert dir at ${MCP_TLS_DIR} — serving HTTP"
        return
    fi

    local pair cert key
    for pair in "${TLS_CERT_PAIRS[@]}"; do
        cert="${MCP_TLS_DIR}/${pair%%:*}"
        key="${MCP_TLS_DIR}/${pair##*:}"
        if [[ -r "${cert}" && -r "${key}" ]]; then
            SSL_ARGS=(--ssl-certfile "${cert}" --ssl-keyfile "${key}")
            TLS_SCHEME="https"
            echo "tls: using cert ${cert} — serving HTTPS"
            return
        fi
    done

    echo "tls: ${MCP_TLS_DIR} exists but holds no readable cert/key pair " \
         "(tls.crt/tls.key, fullchain.pem/privkey.pem, or cert.pem/key.pem readable by uid $(id -u));" \
         "generating a self-signed certificate"
    mkdir -p "${SELF_SIGNED_DIR}"
    openssl req -x509 -newkey rsa:2048 -nodes -days 365 \
        -keyout "${SELF_SIGNED_DIR}/key.pem" \
        -out "${SELF_SIGNED_DIR}/cert.pem" \
        -subj "/CN=localhost" \
        -addext "subjectAltName=DNS:localhost,IP:127.0.0.1" >/dev/null 2>&1
    chmod 600 "${SELF_SIGNED_DIR}/key.pem"
    SSL_ARGS=(--ssl-certfile "${SELF_SIGNED_DIR}/cert.pem" --ssl-keyfile "${SELF_SIGNED_DIR}/key.pem")
    TLS_SCHEME="https"
    echo "tls: using self-signed cert ${SELF_SIGNED_DIR}/cert.pem — serving HTTPS"
}

cmd_start() {
    if cmd_status >/dev/null 2>&1; then
        echo "start: already running"
    else
        # TLS preflight runs as part of container bootstrap, before the server starts.
        # It runs in this shell so SSL_ARGS/TLS_SCHEME persist; its output goes to the
        # container console (so the decision is visible via `docker logs`).
        resolve_tls
        # uvicorn's stdout+stderr are piped through rotatelogs, which both (a) echoes
        # every line to the console (-e) so `docker logs` works, and (b) writes a
        # size-rotated file at ${LOGFILE} on the persistent volume (-n keeps the current
        # log at that stable path plus ${LOG_BACKUPS} older generations). uvicorn is
        # backgrounded directly so $! is its PID for the stop/restart logic; rotatelogs
        # inherits the console fd and keeps feeding it after PID 1 execs tail below.
        /opt/venv/bin/python -m uvicorn rs_mcp_server.server:web \
            --host "${MCP_HOST}" \
            --port "${MCP_PORT}" \
            "${SSL_ARGS[@]}" \
            > >(exec /usr/sbin/rotatelogs -e -n "${LOG_BACKUPS}" "${LOGFILE}" "${LOG_MAX_SIZE}") 2>&1 &
        echo "$!" >"${PIDFILE}"
        echo "start: PID $(cat "${PIDFILE}") on ${TLS_SCHEME}://${MCP_HOST}:${MCP_PORT} (logs: docker logs + ${LOGFILE})"
    fi

    # When invoked as PID 1 (container ENTRYPOINT), keep this script alive so the
    # container doesn't exit after backgrounding uvicorn. From `docker exec` sessions
    # PID is not 1 and we return normally.
    if [[ $$ -eq 1 ]]; then
        exec tail -f /dev/null
    fi
}

cmd_stop() {
    if ! cmd_status >/dev/null 2>&1; then
        echo "stop: already stopped"
        return 0
    fi

    local pid
    pid="$(cat "${PIDFILE}")"
    kill -TERM "${pid}" 2>/dev/null || true

    local i
    for ((i = 0; i < GRACE_SECONDS * 2; i++)); do
        kill -0 "${pid}" 2>/dev/null || break
        sleep 0.5
    done

    if kill -0 "${pid}" 2>/dev/null; then
        kill -KILL "${pid}" 2>/dev/null || true
    fi

    rm -f "${PIDFILE}"
    echo "stop: PID ${pid} terminated"
}

cmd_restart() {
    cmd_stop
    cmd_start
}

usage() {
    cat <<EOF
Usage: $(basename "$0") --start | --stop | --restart | --status

  --start    Start uvicorn as a background process (no-op if running).
  --stop     SIGTERM the uvicorn PID with ${GRACE_SECONDS}s grace, then SIGKILL.
  --restart  Equivalent to --stop followed by --start.
  --status   Print run state and exit 0 (running) or 1 (stopped).

Env: PIDFILE=${PIDFILE} LOGFILE=${LOGFILE} MCP_HOST=${MCP_HOST} MCP_PORT=${MCP_PORT} MCP_TLS_DIR=${MCP_TLS_DIR}
EOF
}

case "${1:-}" in
    --start)   cmd_start ;;
    --stop)    cmd_stop ;;
    --restart) cmd_restart ;;
    --status)  cmd_status ;;
    -h|--help|"") usage ;;
    *)
        usage
        echo
        echo "error: unknown command: $1" >&2
        exit 2
        ;;
esac
